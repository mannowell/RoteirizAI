# Servidor
PORT=5000
NODE_ENV=development

# IA — Groq
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Amadeus Travel API
# Obtenha em: https://developers.amadeus.com/
AMADEUS_CLIENT_ID=SEU_AMADEUS_CLIENT_ID_AQUI
AMADEUS_CLIENT_SECRET=SUA_AMADEUS_CLIENT_SECRET_AQUI
